```php
<?php
// app/Services/SupplierCatalogPersistenceService.php

namespace App\Services;

use App\Models\SupplierProduct;
use App\Models\SupplierProductSku;
use Illuminate\Support\Facades\DB;

class SupplierCatalogPersistenceService
{
    public function store(array $normalized): array
    {
        return DB::transaction(function () use ($normalized): array {
            $product = SupplierProduct::query()->updateOrCreate(
                [
                    'external_product_id' => (string) $normalized['external_product_id'],
                ],
                [
                    'external_offer_id' => $normalized['external_offer_id'] ?? null,
                    'title' => (string) $normalized['title'],
                    'supplier_name' => $normalized['supplier_name'] ?? null,
                    'source_url' => $normalized['source_url'] ?? null,
                    'main_image_url' => $normalized['main_image_url'] ?? null,
                    'category_path_json' => is_array($normalized['category_path_json'] ?? null) ? $normalized['category_path_json'] : null,
                    'attributes_json' => is_array($normalized['attributes_json'] ?? null) ? $normalized['attributes_json'] : null,
                    'product_payload_json' => is_array($normalized['product_payload_json'] ?? null) ? $normalized['product_payload_json'] : null,
                ]
            );

            $seen = [];
            foreach ((array) ($normalized['skus'] ?? []) as $sku) {
                if (! is_array($sku)) {
                    continue;
                }

                $externalSkuId = trim((string) ($sku['external_sku_id'] ?? ''));
                if ($externalSkuId === '') {
                    continue;
                }

                $seen[] = $externalSkuId;

                SupplierProductSku::query()->updateOrCreate(
                    [
                        'supplier_product_id' => $product->id,
                        'external_sku_id' => $externalSkuId,
                    ],
                    [
                        'sku_label' => $sku['sku_label'] ?? null,
                        'variant_attributes_json' => is_array($sku['variant_attributes_json'] ?? null) ? $sku['variant_attributes_json'] : null,
                        'moq' => max(1, (int) ($sku['moq'] ?? 1)),
                        'unit_price' => is_numeric($sku['unit_price'] ?? null) ? (float) $sku['unit_price'] : null,
                        'currency_code' => $sku['currency_code'] ?? null,
                        'available_quantity' => isset($sku['available_quantity']) ? (int) $sku['available_quantity'] : null,
                        'lead_time_days' => isset($sku['lead_time_days']) ? (int) $sku['lead_time_days'] : null,
                        'logistics_modes_json' => is_array($sku['logistics_modes_json'] ?? null) ? $sku['logistics_modes_json'] : null,
                        'sku_payload_json' => is_array($sku['sku_payload_json'] ?? null) ? $sku['sku_payload_json'] : null,
                        'is_active' => (bool) ($sku['is_active'] ?? true),
                    ]
                );
            }

            if ($seen !== []) {
                SupplierProductSku::query()
                    ->where('supplier_product_id', $product->id)
                    ->whereNotIn('external_sku_id', $seen)
                    ->delete();
            }

            $product->load('skus');

            return [
                'id' => $product->id,
                'external_product_id' => $product->external_product_id,
                'external_offer_id' => $product->external_offer_id,
                'title' => $product->title,
                'supplier_name' => $product->supplier_name,
                'source_url' => $product->source_url,
                'main_image_url' => $product->main_image_url,
                'category_path_json' => $product->category_path_json,
                'attributes_json' => $product->attributes_json,
                'product_payload_json' => $product->product_payload_json,
                'skus' => $product->skus->map(fn (SupplierProductSku $sku) => [
                    'id' => $sku->id,
                    'external_sku_id' => $sku->external_sku_id,
                    'sku_label' => $sku->sku_label,
                    'variant_attributes_json' => $sku->variant_attributes_json,
                    'moq' => $sku->moq,
                    'unit_price' => $sku->unit_price,
                    'currency_code' => $sku->currency_code,
                    'available_quantity' => $sku->available_quantity,
                    'lead_time_days' => $sku->lead_time_days,
                    'logistics_modes_json' => $sku->logistics_modes_json,
                    'sku_payload_json' => $sku->sku_payload_json,
                    'is_active' => $sku->is_active,
                ])->values()->all(),
            ];
        });
    }
}
```

```php
<?php
// app/Services/AliExpressDsProductImportService.php

namespace App\Services;

use App\Exceptions\AliExpressImportDiagnosticException;
use Illuminate\Support\Facades\Log;
use RuntimeException;

class AliExpressDsProductImportService
{
    public function __construct(
        private readonly AliExpressTopClient $client,
        private readonly SupplierCatalogPersistenceService $persistence,
    ) {
    }

    public function importByExternalProductId(array $input): array
    {
        $externalProductId = trim((string) ($input['external_product_id'] ?? ''));
        $shipToCountry = strtoupper(trim((string) ($input['ship_to_country'] ?? config('aliexpress_ds.default_ship_to_country', 'TG'))));
        $targetCurrency = strtoupper(trim((string) ($input['target_currency'] ?? config('aliexpress_ds.default_target_currency', 'USD'))));
        $targetLanguage = trim((string) ($input['target_language'] ?? config('aliexpress_ds.default_target_language', 'fr')));
        $remoteMode = trim((string) ($input['remote_mode'] ?? 'ds_product'));

        if ($externalProductId === '') {
            throw new RuntimeException('external_product_id manquant.');
        }

        $candidates = $remoteMode === 'ds_wholesale'
            ? [
                config('aliexpress_ds.product_wholesale_method', 'aliexpress.ds.product.wholesale.get'),
                config('aliexpress_ds.product_get_method', 'aliexpress.ds.product.get'),
            ]
            : [
                config('aliexpress_ds.product_get_method', 'aliexpress.ds.product.get'),
                config('aliexpress_ds.product_wholesale_method', 'aliexpress.ds.product.wholesale.get'),
            ];

        $attempts = [];
        $lastRaw = null;
        $lastErrorCode = null;
        $lastRequestId = null;

        foreach ($candidates as $index => $method) {
            $attempts[] = $method;

            Log::info('aliexpress_ds.import_attempt', [
                'external_product_id' => $externalProductId,
                'ship_to_country' => $shipToCountry,
                'target_currency' => $targetCurrency,
                'target_language' => $targetLanguage,
                'attempt_method' => $method,
            ]);

            $raw = $this->client->call($method, [
                'ship_to_country' => $shipToCountry,
                'product_id' => $externalProductId,
                'target_currency' => $targetCurrency,
                'target_language' => $targetLanguage,
                'remove_personal_benefit' => 'false',
            ]);

            $lastRaw = $raw;
            $lastErrorCode = $this->findFirstStringByKeys($raw, ['error_code', 'errorCode', 'code', 'sub_code', 'subCode']);
            $lastRequestId = $this->findFirstStringByKeys($raw, ['request_id', 'requestId']);

            Log::info('aliexpress_ds.import_response_summary', [
                'external_product_id' => $externalProductId,
                'attempt_method' => $method,
                'provider_error_code' => $lastErrorCode,
                'provider_request_id' => $lastRequestId,
                'response_shape' => $this->describeResponseShape($raw),
            ]);

            $normalized = $this->normalizeDsProduct($externalProductId, $raw, [
                'ship_to_country' => $shipToCountry,
                'target_currency' => $targetCurrency,
                'target_language' => $targetLanguage,
                'resolved_remote_mode' => $method === config('aliexpress_ds.product_wholesale_method') ? 'ds_wholesale' : 'ds_product',
            ]);

            if ($this->isUsable($normalized)) {
                return [
                    'product' => $this->persistence->store($normalized),
                    'meta' => [
                        'resolved_remote_mode' => $normalized['attributes_json']['import_mode'] ?? 'ds_product',
                        'fallback_used' => $index > 0,
                        'ship_to_country' => $shipToCountry,
                    ],
                ];
            }
        }

        Log::warning('aliexpress_ds.import_failed', [
            'external_product_id' => $externalProductId,
            'ship_to_country' => $shipToCountry,
            'attempts' => $attempts,
            'provider_error_code' => $lastErrorCode,
            'provider_request_id' => $lastRequestId,
        ]);

        throw new AliExpressImportDiagnosticException(
            $this->buildErrorMessage($lastErrorCode, $lastRaw),
            [
                'external_product_id' => $externalProductId,
                'ship_to_country' => $shipToCountry,
                'attempts' => $attempts,
                'provider_error_code' => $lastErrorCode,
                'provider_request_id' => $lastRequestId,
                'response_shape' => $this->describeResponseShape($lastRaw),
            ]
        );
    }

    private function buildErrorMessage(?string $errorCode, ?array $raw): string
    {
        $code = strtoupper((string) $errorCode);

        return match ($code) {
            'ISP.INVALID-TOKEN', 'INVALID_SESSION', 'INVALID_ACCESS_TOKEN' => 'Le token AliExpress semble invalide ou expire. Reconnecte le compte OAuth puis relance l import.',
            'ISV.INVALID-PERMISSION', 'FORBIDDEN', 'INSUFFICIENT_ISV_PERMISSIONS' => 'Le compte AliExpress connecte n a pas les permissions Dropshipping pour cette API.',
            default => $this->describeResponseShape($raw) === 'result_without_skus'
                ? 'Le produit AliExpress a ete lu mais aucun SKU exploitable n a ete trouve.'
                : 'Produit AliExpress DS introuvable ou non lisible pour cet External product ID. Verifie l ID, le pays de destination, les droits DS du compte et le token OAuth.',
        };
    }

    private function isUsable(array $normalized): bool
    {
        if (trim((string) ($normalized['title'] ?? '')) === '') {
            return false;
        }

        foreach ((array) ($normalized['skus'] ?? []) as $sku) {
            if (is_array($sku) && trim((string) ($sku['external_sku_id'] ?? '')) !== '') {
                return true;
            }
        }

        return false;
    }

    private function normalizeDsProduct(string $externalProductId, array $payload, array $options = []): array
    {
        $result = is_array($payload['result'] ?? null)
            ? $payload['result']
            : (is_array(data_get($payload, 'aliexpress_ds_product_get_response.result'))
                ? data_get($payload, 'aliexpress_ds_product_get_response.result')
                : (is_array(data_get($payload, 'aliexpress_ds_product_wholesale_get_response.result'))
                    ? data_get($payload, 'aliexpress_ds_product_wholesale_get_response.result')
                    : []));

        $baseInfo = is_array($result['ae_item_base_info_dto'] ?? null) ? $result['ae_item_base_info_dto'] : [];
        $storeInfo = is_array($result['ae_store_info'] ?? null) ? $result['ae_store_info'] : [];
        $packageInfo = is_array($result['package_info_dto'] ?? null) ? $result['package_info_dto'] : [];
        $logisticsInfo = is_array($result['logistics_info_dto'] ?? null) ? $result['logistics_info_dto'] : [];
        $productConverter = is_array($result['product_id_converter_result'] ?? null) ? $result['product_id_converter_result'] : [];
        $multimedia = is_array($result['ae_multimedia_info_dto'] ?? null) ? $result['ae_multimedia_info_dto'] : [];

        $title = trim((string) ($baseInfo['subject'] ?? $baseInfo['title'] ?? '')) ?: ('Produit ' . $externalProductId);
        $imageUrlsRaw = trim((string) ($multimedia['image_urls'] ?? ''));
        $imageUrls = array_values(array_filter(array_map('trim', explode(';', $imageUrlsRaw))));
        $mainImageUrl = $imageUrls[0] ?? null;
        $targetCurrency = strtoupper(trim((string) ($options['target_currency'] ?? 'USD'))) ?: 'USD';

        $normalizedSkus = [];
        foreach ((array) ($result['ae_item_sku_info_dtos'] ?? []) as $sku) {
            if (! is_array($sku)) {
                continue;
            }

            $externalSkuId = trim((string) ($sku['sku_id'] ?? $sku['skuId'] ?? $sku['selectedSkuId'] ?? $sku['selected_sku_id'] ?? $sku['id'] ?? ''));
            if ($externalSkuId === '') {
                continue;
            }

            $normalizedSkus[] = [
                'external_sku_id' => $externalSkuId,
                'sku_label' => $sku['sku_attr'] ?? $externalSkuId,
                'variant_attributes_json' => $this->normalizeVariantAttributes($sku),
                'moq' => max(1, (int) ($sku['sku_bulk_order'] ?? 1)),
                'unit_price' => $this->resolveMoneyValue($sku, ['offer_sale_price', 'target_sale_price', 'sale_price', 'sku_price', 'price']),
                'currency_code' => $sku['currency_code'] ?? $targetCurrency,
                'available_quantity' => isset($sku['sku_available_stock']) ? (int) $sku['sku_available_stock'] : (isset($sku['ipm_sku_stock']) ? (int) $sku['ipm_sku_stock'] : null),
                'lead_time_days' => null,
                'logistics_modes_json' => [],
                'sku_payload_json' => $sku,
                'is_active' => filter_var($sku['sku_stock'] ?? true, FILTER_VALIDATE_BOOLEAN, FILTER_NULL_ON_FAILURE) !== false,
            ];
        }

        return [
            'external_product_id' => $externalProductId,
            'external_offer_id' => $productConverter['main_product_id'] ?? null,
            'title' => $title,
            'supplier_name' => $storeInfo['store_name'] ?? 'AliExpress',
            'source_url' => 'https://www.aliexpress.com/item/' . $externalProductId . '.html',
            'main_image_url' => $mainImageUrl,
            'category_path_json' => array_values(array_filter([
                trim((string) ($baseInfo['category_sequence'] ?? '')),
                trim((string) ($baseInfo['category_id'] ?? '')),
            ])),
            'attributes_json' => [
                'target_currency' => $targetCurrency,
                'target_language' => $options['target_language'] ?? null,
                'ship_to_country' => $options['ship_to_country'] ?? null,
                'delivery_time' => $logisticsInfo['delivery_time'] ?? null,
                'gross_weight' => $packageInfo['gross_weight'] ?? null,
                'import_mode' => $options['resolved_remote_mode'] ?? 'ds_product',
            ],
            'product_payload_json' => array_merge($payload, ['result' => $result]),
            'skus' => $normalizedSkus,
        ];
    }

    private function normalizeVariantAttributes(array $sku): array
    {
        $rows = [];
        foreach ((array) ($sku['ae_sku_property_dtos'] ?? $sku['sku_property_list'] ?? []) as $property) {
            if (! is_array($property)) {
                continue;
            }

            $rows[] = array_filter([
                'property_id' => $property['sku_property_id'] ?? null,
                'property_value_id' => $property['property_value_id'] ?? null,
                'property_name' => $property['sku_property_name'] ?? null,
                'property_value' => $property['property_value_definition_name'] ?? $property['sku_property_value'] ?? null,
                'sku_image' => $property['sku_image'] ?? null,
            ], static fn ($value) => $value !== null && $value !== '');
        }

        return array_values(array_filter($rows));
    }

    private function resolveMoneyValue(array $payload, array $keys): ?float
    {
        foreach ($keys as $key) {
            $value = data_get($payload, $key);
            if (is_numeric($value)) {
                return (float) $value;
            }

            if (is_string($value)) {
                $normalized = str_replace(',', '.', trim($value));
                if (is_numeric($normalized)) {
                    return (float) $normalized;
                }
            }
        }

        return null;
    }

    private function describeResponseShape(?array $payload): string
    {
        if (! is_array($payload) || $payload === []) {
            return 'empty_payload';
        }

        $result = is_array($payload['result'] ?? null)
            ? $payload['result']
            : (is_array(data_get($payload, 'aliexpress_ds_product_get_response.result'))
                ? data_get($payload, 'aliexpress_ds_product_get_response.result')
                : (is_array(data_get($payload, 'aliexpress_ds_product_wholesale_get_response.result'))
                    ? data_get($payload, 'aliexpress_ds_product_wholesale_get_response.result')
                    : null));

        if (! is_array($result) || $result === []) {
            return 'empty_result';
        }

        if (! is_array($result['ae_item_base_info_dto'] ?? null) || ($result['ae_item_base_info_dto'] ?? []) === []) {
            return 'result_without_base_info';
        }

        if (! is_array($result['ae_item_sku_info_dtos'] ?? null) || ($result['ae_item_sku_info_dtos'] ?? []) === []) {
            return 'result_without_skus';
        }

        return 'result_with_base_info_and_skus';
    }

    private function findFirstStringByKeys(array $payload, array $keys): ?string
    {
        $needle = array_flip(array_map(static fn ($key) => strtolower((string) $key), $keys));
        $stack = [$payload];

        while ($stack !== []) {
            $node = array_pop($stack);
            if (! is_array($node)) {
                continue;
            }

            foreach ($node as $key => $value) {
                if (is_array($value)) {
                    $stack[] = $value;
                    continue;
                }

                if (is_string($key) && isset($needle[strtolower($key)])) {
                    $string = trim((string) $value);
                    if ($string !== '') {
                        return $string;
                    }
                }
            }
        }

        return null;
    }
}
```

```php
<?php
// app/Http/Controllers/Api/AdminAliExpressDsImportController.php

namespace App\Http\Controllers\Api;

use App\Http\Controllers\Controller;
use App\Services\AliExpressDsProductImportService;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Log;
use Throwable;

class AdminAliExpressDsImportController extends Controller
{
    public function import(Request $request, AliExpressDsProductImportService $service)
    {
        $data = $request->validate([
            'external_product_id' => 'required|string|max:255',
            'ship_to_country' => 'nullable|string|size:2',
            'target_currency' => 'nullable|string|max:8',
            'target_language' => 'nullable|string|max:16',
            'remote_mode' => 'nullable|in:ds_product,ds_wholesale',
        ]);

        try {
            $result = $service->importByExternalProductId([
                'external_product_id' => (string) $data['external_product_id'],
                'ship_to_country' => strtoupper((string) ($data['ship_to_country'] ?? config('aliexpress_ds.default_ship_to_country', 'TG'))),
                'target_currency' => strtoupper((string) ($data['target_currency'] ?? config('aliexpress_ds.default_target_currency', 'USD'))),
                'target_language' => (string) ($data['target_language'] ?? config('aliexpress_ds.default_target_language', 'fr')),
                'remote_mode' => (string) ($data['remote_mode'] ?? 'ds_product'),
            ]);

            return response()->json([
                'success' => true,
                'data' => $result['product'],
                'meta' => $result['meta'],
            ], 201);
        } catch (Throwable $exception) {
            Log::warning('aliexpress_ds.controller_import_failed', [
                'external_product_id' => (string) ($data['external_product_id'] ?? ''),
                'message' => $exception->getMessage(),
            ]);

            return response()->json([
                'success' => false,
                'message' => $exception->getMessage(),
                'debug' => method_exists($exception, 'context') ? $exception->context() : null,
            ], 400);
        }
    }
}
