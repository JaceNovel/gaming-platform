[CONFIG_ALREADY_PRESENT]
FILE=backend/config/services.php
HAS=oauth endpoints aliexpress
HAS=ds method mapping
HAS=affiliate and fulfillment related method mapping

[CORE_APIS_TO_USE]
API_1=aliexpress.ds.product.get
USAGE_1=rafraichir produit DS et retrouver les vrais SKU

API_2=aliexpress.ds.product.wholesale.get
USAGE_2=recuperer les donnees wholesale et completer la resolution SKU

API_3=aliexpress.ds.freight.query
USAGE_3=valider service logistique exact, SKU, pays, quantite, devise

API_4=aliexpress.ds.order.create
USAGE_4=creer la commande DS et tenter l auto-paiement

API_5=aliexpress.trade.ds.order.get
USAGE_5=recuperer statut distant de la commande fournisseur

API_6=aliexpress.ds.order.tracking.get
USAGE_6=recuperer tracking et progression logistique

API_7=aliexpress.ds.member.benefit.get
USAGE_7=controle technique de l etat et de l eligibilite DS du compte

API_8=aliexpress.ds.address.get
USAGE_8=non integre actuellement, utile si on veut s appuyer sur les adresses DS natives AliExpress

API_9=DROPSHIPPER_ORDER_STATUS_UPDATE
USAGE_9=webhook a integrer pour avoir une synchronisation event-driven des changements de statut

[LOCAL_SERVICES_ALREADY_USED]
SERVICE_1=App\Services\SupplierApiClient
ROLE_1=client unifie AliExpress / Alibaba avec mapping des operations IOP et normalisation des reponses

SERVICE_2=App\Services\AliExpressOrderFulfillmentService
ROLE_2=creation DS commande unitaire, precheck freight, sync remote, tracking, invoice, fulfilment

SERVICE_3=App\Services\AliExpressProcurementBatchService
ROLE_3=creation DS groupee pour batches fournisseur

SERVICE_4=App\Services\ProcurementBatchService
ROLE_4=construction des batches, regroupement, verification MOQ, auto-drafts

SERVICE_5=App\Services\GroupedLotService
ROLE_5=calcul seuil de grouping, MOQ effectif, montant minimum de lot

[ADMIN_ROUTES_ALREADY_PRESENT]
ORDER_DRAFT_GET=/api/admin/orders/{order}/supplier/aliexpress/ds-draft
ORDER_CREATE_POST=/api/admin/orders/{order}/supplier/aliexpress/create-order
ORDER_SYNC_POST=/api/admin/orders/{order}/supplier/aliexpress/sync-order
GROUPED_READY_GET=/api/admin/sourcing/grouped-ready?platform=aliexpress
BATCH_DRAFT_GET=/api/admin/sourcing/batches/{procurementBatch}/aliexpress/ds-draft
BATCH_CREATE_POST=/api/admin/sourcing/batches/{procurementBatch}/aliexpress/create-order

[MAIN_ORDER_FLOW]
STEP_1=commande client payee sur la plateforme
STEP_2=commande rattachee a AliExpress comme fournisseur
STEP_3=resolution du compte fournisseur AliExpress
STEP_4=resolution de l adresse hub/fournisseur
STEP_5=construction du draft DS
STEP_6=verification de chaque ligne via ds.freight.query
STEP_7=reecriture des logistics_service_name avec la valeur exacte retournee par AliExpress
STEP_8=appel ds.order.create avec USD + try_to_pay=true
STEP_9=persistance des payloads request/response
STEP_10=si success sans warning paiement => statut fournisseur paid
STEP_11=si success avec warning paiement => statut fournisseur pending
STEP_12=sync ulterieure via ds.trade.order.get + ds.order.tracking.get

[BATCH_FLOW]
STEP_1=collecter les ProcurementDemand pending
STEP_2=exiger order.status=payment_success
STEP_3=exiger grouping_released_at non null
STEP_4=verifier MOQ fournisseur atteint
STEP_5=verifier meme fournisseur, meme destination, meme devise
STEP_6=creer procurement_batch draft
STEP_7=construire un payload DS groupe
STEP_8=precheck freight par ligne
STEP_9=appeler ds.order.create pour tout le batch
STEP_10=stocker metadata dans procurement_batches.supplier_order_payload_json

[REQUIRED_CREATE_PAYLOAD_RULES]
RULE_1=ds_extend_request.payment.pay_currency doit etre USD
RULE_2=ds_extend_request.payment.try_to_pay doit etre true
RULE_3=param_place_order_request4_open_api_d_t_o.out_order_id doit etre unique
RULE_4=param_place_order_request4_open_api_d_t_o.logistics_address doit etre complet
RULE_5=chaque product_item doit avoir product_id
RULE_6=chaque product_item doit avoir product_count >= 1
RULE_7=chaque product_item doit avoir logistics_service_name valide
RULE_8=sku_attr doit correspondre exactement au SKU choisi quand necessaire

[REFERENCE_CREATE_PAYLOAD]
{
  "ds_extend_request": {
    "payment": {
      "pay_currency": "USD",
      "try_to_pay": "true"
    }
  },
  "param_place_order_request4_open_api_d_t_o": {
    "out_order_id": "gp-order-123-abc",
    "logistics_address": {
      "country": "FR",
      "province": "Yvelines",
      "city": "Maisons-Laffitte",
      "address": "42 RUE DE PARIS, CENTRE MBE 2538",
      "zip": "78600",
      "contact_person": "LAWSON-BODY",
      "full_name": "LAWSON-BODY",
      "mobile_no": "612345678",
      "phone": "612345678",
      "phone_country": "+33",
      "locale": "fr_FR"
    },
    "product_items": [
      {
        "product_id": "1005001234567890",
        "sku_attr": "200007763:201336100",
        "product_count": "1",
        "logistics_service_name": "AliExpress Selection Standard",
        "order_memo": "Commande locale ORD-123"
      }
    ]
  }
}

[FREIGHT_PRECHECK_RULES]
CHECK_1=product_id present
CHECK_2=selectedSkuId numerique resolu depuis supplier_sku
CHECK_3=service logistique disponible pour le SKU
CHECK_4=quantite coherente
CHECK_5=devise coherente
CHECK_6=destination supportee

On ne doit jamais creer une commande DS sans precheck freight immediat avant create-order.

[SKU_MAPPING_RULES]
RULE_1=ne jamais choisir le plus ancien SKU par defaut sans verification
RULE_2=privilegier les SKU actifs DS avec selectedSkuId numerique
RULE_3=si le mapping pointe vers un placeholder ou un SKU non numerique, rafraichir via ds.product.get puis ds.product.wholesale.get
RULE_4=ne relier un nouveau SKU que s il est sur et numerique

[LOGISTICS_RULES]
RULE_1=la famille standard AliExpress peut apparaitre sous plusieurs noms
RULE_2=les alias standard doivent etre consideres equivalents pour matching
RULE_3=au moment du create-order, le payload doit contenir le nom exact retourne par ds.freight.query
RULE_4=memoriser la valeur resolue dans le mapping local pour stabiliser les appels suivants

[ALIASES_TO_RECOGNIZE]
STANDARD_1=AliExpress Selection Standard
STANDARD_2=AliExpress Standard Shipping
STANDARD_3=Expedition standard AliExpress
PREMIUM_1=AliExpress Premium shipping
PREMIUM_2=Expedition premium AliExpress

[PAYMENT_RESULT_INTERPRETATION]
CASE_1=create_success_and_payment_success
LOCAL_EFFECT_1=supplier_status=paid

CASE_2=create_success_but_autoPay_fail
LOCAL_EFFECT_2=supplier_status=pending
ACTION_2=marquer payment warning et exiger reprise/review

CASE_3=create_fail
LOCAL_EFFECT_3=supplier_status inchange ou erreur selon contexte
ACTION_3=stocker l erreur et bloquer la progression fulfilment

[COMMON_REMOTE_ERRORS]
ERROR_1=B_DROPSHIPPER_DELIVERY_ADDRESS_VALIDATE_FAIL
MEANING_1=adresse hub ou livraison invalide

ERROR_2=BLACKLIST_BUYER_IN_LIST
MEANING_2=compte acheteur AliExpress invalide ou blackliste

ERROR_3=USER_ACCOUNT_DISABLED
MEANING_3=compte acheteur desactive

ERROR_4=PRICE_PAY_CURRENCY_ERROR
MEANING_4=devise incoherente, DS doit rester en USD

ERROR_5=DELIVERY_METHOD_NOT_EXIST
MEANING_5=service logistique invalide pour le SKU

ERROR_6=INVENTORY_HOLD_ERROR
MEANING_6=stock insuffisant ou indisponible

ERROR_7=REPEATED_ORDER_ERROR
MEANING_7=AliExpress considere la commande comme doublon

ERROR_8=InsufficientPermission
MEANING_8=scopes DS manquants ou compte non autorise pour l operation

[LOCAL_STATUS_EXPECTED]
ORDER_SUPPLIER_STATUS_1=pending
ORDER_SUPPLIER_STATUS_2=paid
ORDER_SUPPLIER_STATUS_3=grouping
ORDER_SUPPLIER_STATUS_4=supplier_ordered
ORDER_SUPPLIER_STATUS_5=warehouse_received
ORDER_SUPPLIER_STATUS_6=delivering
ORDER_SUPPLIER_STATUS_7=delivered

